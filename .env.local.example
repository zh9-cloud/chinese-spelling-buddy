# ─── Google Cloud TTS (required for voice playback) ────────────────────────
# https://console.cloud.google.com
GOOGLE_TTS_API_KEY=your_google_tts_key_here

# ─── Supabase (required for account system / cloud sync) ───────────────────
# 1. Create a free project at https://supabase.com
# 2. Settings → API → copy "Project URL" and "anon public" key
# 3. Run supabase-schema.sql in the SQL Editor (Project → SQL Editor)
# 4. Settings → Authentication → URL Configuration → add Site URL and
#    Redirect URL: http://localhost:3000/api/auth/callback
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── OpenAI (required for photo OCR + handwriting grading) ─────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# ─── Email reminders (Resend + daily Vercel Cron) ──────────────────────────
# Resend API key — https://resend.com  (free tier sends only to your own
# address until you verify a sending domain).
RESEND_API_KEY=re_your_resend_key_here
# Optional sender; needs a verified domain to email real parents.
# REMINDER_FROM=Chinese Spelling Buddy <reminders@yourdomain.com>
# Supabase service_role key (SECRET, server-only) — Settings → API.
# Lets the cron read every parent's lists + email. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Any random string; Vercel sends it as a Bearer token on cron calls.
CRON_SECRET=your_random_secret_here
